#!/usr/bin/env bash
set -euo pipefail

# Only check staged Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    exit 0
fi

echo "Running pre-commit checks on Go files..."

# Check gofmt
UNFORMATTED=$(gofmt -l $STAGED_GO_FILES 2>&1 || true)
if [ -n "$UNFORMATTED" ]; then
    echo "❌ gofmt: the following files need formatting:"
    echo "$UNFORMATTED"
    echo ""
    echo "Run: gofmt -w $UNFORMATTED"
    exit 1
fi
echo "✅ gofmt"

# Run golangci-lint on changed packages
PACKAGES=$(echo "$STAGED_GO_FILES" | xargs -I{} dirname {} | sort -u | sed 's|^|./|')
if ! golangci-lint run $PACKAGES 2>&1; then
    echo ""
    echo "❌ golangci-lint: fix the issues above before committing"
    exit 1
fi
echo "✅ golangci-lint"
